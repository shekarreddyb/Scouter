<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\EventOverlay.Core\EventOverlay.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="XamlAnimatedGif" Version="2.2.0" />
    <!-- No .NET 10-compatible WPF Lottie package exists yet.
         LottieSharp targets .NET Framework and has incompatible types (LottieSharp.Path etc).
         Lottie files are handled at runtime with a skip + debug log; convert to GIF as workaround. -->
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

</Project>
